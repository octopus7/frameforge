<Window x:Class="FrameForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FrameForge Tool"
        Height="900"
        Width="1400"
        MinHeight="620"
        MinWidth="960"
        Background="#1A1A1A"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#3A3A3A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1E1E1E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThumbnailItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="5"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#233549" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#66B6FF" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#9DD0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="6" />
            <RowDefinition Height="200" MinHeight="120" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0"
              Background="#222222"
              Foreground="#F2F2F2"
              BorderBrush="#2F2F2F"
              BorderThickness="0,0,0,1">
            <Menu.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#222222" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#F2F2F2" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#222222" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#F2F2F2" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#35506A" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />

                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#F2F2F2" />
                    <Setter Property="Background" Value="#222222" />
                    <Setter Property="BorderBrush" Value="#2F2F2F" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="8,4" />
                </Style>
            </Menu.Resources>

            <MenuItem Header="파일">
                <MenuItem Header="새 프로젝트"
                          InputGestureText="Ctrl+N"
                          Click="NewProjectMenuItem_Click" />
                <MenuItem Header="프로젝트 열기..."
                          InputGestureText="Ctrl+O"
                          Click="OpenProjectMenuItem_Click" />
                <MenuItem Header="저장"
                          InputGestureText="Ctrl+S"
                          Click="SaveProjectMenuItem_Click" />
                <MenuItem Header="다른 이름으로 저장..."
                          InputGestureText="Ctrl+Shift+S"
                          Click="SaveProjectAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="단일 이미지에서 시트 가져오기"
                          Click="ImportSingleImageSheetMenuItem_Click" />
                <Separator />
                <MenuItem Header="종료"
                          InputGestureText="Alt+F4"
                          Click="ExitMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1"
                Margin="10,10,10,6"
                Background="#101010"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14">
                    <Border Background="#161616"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            Padding="20"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Image Source="{Binding CurrentFrameImage}"
                               Stretch="None"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True">
                            <Image.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomFactor}"
                                                ScaleY="{Binding ZoomFactor}" />
                            </Image.LayoutTransform>
                        </Image>
                    </Border>
                </ScrollViewer>

                <TextBlock Text="{Binding EmptyFrameMessage}"
                           Foreground="#7D7D7D"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFrames}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="2"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="#2D2D2D" />

        <Border Grid.Row="3"
                Margin="10,6,10,10"
                Background="#141414"
                BorderBrush="#2F2F2F"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="8,6,8,6">
                    <Border DockPanel.Dock="Left"
                            BorderBrush="#4A4A4A"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#262626">
                        <UniformGrid Rows="1" Columns="3">
                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0,0,1,0"
                                    Click="PreviousFrameButton_Click"
                                    ToolTip="Previous frame">
                                <Path Fill="#EFEFEF" Data="M1,1 H3 V15 H1 Z M14,1 L4,8 L14,15 Z" />
                            </Button>

                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0,0,1,0"
                                    Click="PlayPauseButton_Click"
                                    ToolTip="Play/Pause">
                                <Grid Width="14" Height="14">
                                    <Path Fill="#EFEFEF" Data="M2,1 L13,8 L2,15 Z">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Rectangle Fill="#EFEFEF"
                                               Width="10"
                                               Height="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0"
                                    Click="NextFrameButton_Click"
                                    ToolTip="Next frame">
                                <Path Fill="#EFEFEF" Data="M13,1 H15 V15 H13 Z M2,1 L12,8 L2,15 Z" />
                            </Button>
                        </UniformGrid>
                    </Border>

                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource TransportButtonStyle}"
                            Width="40"
                            Margin="8,0,0,0"
                            Click="AddFramesButton_Click"
                            ToolTip="Add frame images">
                        <Path Stroke="#EFEFEF"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M8,2 V14 M2,8 H14" />
                    </Button>

                    <CheckBox Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Foreground="#D0D0D0"
                              Content="루프"
                              IsChecked="{Binding IsLoopEnabled}"
                              ToolTip="켜면 좌우 이동과 재생이 순환합니다." />

                    <TextBlock VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="#A8A8A8"
                               Text="{Binding CurrentFrameSummary}" />
                </DockPanel>

                <ListBox Grid.Row="1"
                         x:Name="ThumbnailList"
                         Margin="6,0,6,6"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         ItemsSource="{Binding Frames}"
                         SelectedIndex="{Binding SelectedFrameIndex, Mode=TwoWay}"
                         SelectionChanged="ThumbnailList_SelectionChanged"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="ThumbnailList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ThumbnailList_PreviewMouseMove"
                         PreviewDragOver="ThumbnailList_PreviewDragOver"
                         Drop="ThumbnailList_Drop"
                         SizeChanged="ThumbnailList_SizeChanged"
                         ItemContainerStyle="{StaticResource ThumbnailItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6"
                                    Padding="6"
                                    MinWidth="92"
                                    Background="#222222"
                                    BorderBrush="#3C3C3C"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel>
                                    <Image Source="{Binding Image}"
                                           Height="{Binding DataContext.ThumbnailHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Stretch="Uniform" />
                                    <TextBlock Text="{Binding Name}"
                                               Margin="0,4,0,0"
                                               Foreground="#D9D9D9"
                                               FontSize="11"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>

