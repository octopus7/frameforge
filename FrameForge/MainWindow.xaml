<Window x:Class="FrameForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FrameForge Tool"
        Height="900"
        Width="1400"
        MinHeight="620"
        MinWidth="960"
        Background="{StaticResource Brush.WindowBackground}"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="{StaticResource Brush.ControlBackground}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Brush.ControlHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Brush.ControlPressed}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThumbnailItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="5"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentFocus}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="6" />
            <RowDefinition Height="200" MinHeight="120" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0"
              Background="{StaticResource Brush.SurfaceCard}"
              Foreground="{StaticResource Brush.TextPrimary}"
              BorderBrush="{StaticResource Brush.BorderDefault}"
              BorderThickness="0,0,0,1">
            <Menu.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource Color.SurfaceCard}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource Color.SurfaceCard}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource Color.AccentBackground}" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />

                <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="{x:Type Separator}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Separator}">
                                <Border Height="1"
                                        Margin="8,4"
                                        Background="{StaticResource Brush.BorderDefault}" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <ControlTemplate x:Key="{x:Static MenuItem.TopLevelHeaderTemplateKey}" TargetType="{x:Type MenuItem}">
                    <Border x:Name="TopLevelHeaderBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter ContentSource="Header"
                                              Margin="12,6"
                                              RecognizesAccessKey="True" />
                            <Popup x:Name="TopLevelHeaderPopup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border x:Name="TopLevelHeaderPopupBorder"
                                        Margin="0,1,0,0"
                                        Background="{StaticResource Brush.SurfaceCard}"
                                        BorderBrush="{StaticResource Brush.BorderDefault}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="TopLevelHeaderBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="TopLevelHeaderBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="TopLevelHeaderBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="TopLevelHeaderBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TopLevelHeaderBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <ControlTemplate x:Key="{x:Static MenuItem.TopLevelItemTemplateKey}" TargetType="{x:Type MenuItem}">
                    <Border x:Name="TopLevelItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Header"
                                          Margin="12,6"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="TopLevelItemBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="TopLevelItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TopLevelItemBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <ControlTemplate x:Key="{x:Static MenuItem.SubmenuHeaderTemplateKey}" TargetType="{x:Type MenuItem}">
                    <Border x:Name="SubmenuHeaderBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              Margin="10,6,10,6"
                                              RecognizesAccessKey="True" />

                            <Path Grid.Column="2"
                                  Margin="0,0,8,0"
                                  Width="5"
                                  Height="9"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Fill="{StaticResource Brush.TextMuted}"
                                  Data="M0,0 L5,4.5 L0,9 Z" />

                            <Popup x:Name="SubmenuHeaderPopup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Right"
                                   PopupAnimation="Fade">
                                <Border x:Name="SubmenuHeaderPopupBorder"
                                        Margin="1,0,0,0"
                                        Background="{StaticResource Brush.SurfaceCard}"
                                        BorderBrush="{StaticResource Brush.BorderDefault}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="SubmenuHeaderBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="SubmenuHeaderBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="SubmenuHeaderBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="SubmenuHeaderBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SubmenuHeaderBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <ControlTemplate x:Key="{x:Static MenuItem.SubmenuItemTemplateKey}" TargetType="{x:Type MenuItem}">
                    <Border x:Name="SubmenuItemBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Path x:Name="SubmenuCheckGlyph"
                                  Grid.Column="0"
                                  Margin="4,0,0,0"
                                  Width="8"
                                  Height="8"
                                  VerticalAlignment="Center"
                                  Fill="{StaticResource Brush.TextPrimary}"
                                  Data="M0,4 L3,7 L8,1"
                                  Visibility="Collapsed" />

                            <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              Margin="10,6,14,6"
                                              RecognizesAccessKey="True" />

                            <TextBlock Grid.Column="2"
                                       Margin="16,6,14,6"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       Text="{TemplateBinding InputGestureText}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="SubmenuItemBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="SubmenuItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                        </Trigger>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="SubmenuCheckGlyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SubmenuCheckGlyph" Property="Opacity" Value="0" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SubmenuCheckGlyph" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SubmenuCheckGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SubmenuItemBorder" Property="Opacity" Value="0.45" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

                <Style TargetType="{x:Type MenuItem}">
                    <Setter Property="OverridesDefaultStyle" Value="True" />
                    <Setter Property="SnapsToDevicePixels" Value="True" />
                    <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                    <Setter Property="Background" Value="{StaticResource Brush.SurfaceCard}" />
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="8,4" />
                    <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.TopLevelItemTemplateKey}}" />
                    <Style.Triggers>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.TopLevelHeaderTemplateKey}}" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelItem">
                            <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.TopLevelItemTemplateKey}}" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.SubmenuHeaderTemplateKey}}" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter Property="Template" Value="{StaticResource {x:Static MenuItem.SubmenuItemTemplateKey}}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Menu.Resources>

            <MenuItem Header="파일">
                <MenuItem Header="새 프로젝트"
                          InputGestureText="Ctrl+N"
                          Click="NewProjectMenuItem_Click" />
                <MenuItem Header="프로젝트 열기..."
                          InputGestureText="Ctrl+O"
                          Click="OpenProjectMenuItem_Click" />
                <MenuItem Header="저장"
                          InputGestureText="Ctrl+S"
                          Click="SaveProjectMenuItem_Click" />
                <MenuItem Header="다른 이름으로 저장..."
                          InputGestureText="Ctrl+Shift+S"
                          Click="SaveProjectAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="가져오기">
                    <MenuItem Header="단일 이미지에서 시트 가져오기"
                              Click="ImportSingleImageSheetMenuItem_Click" />
                    <MenuItem Header="동영상에서 프레임 가져오기"
                              Click="ImportVideoMenuItem_Click" />
                </MenuItem>
                <MenuItem Header="익스포트">
                    <MenuItem Header="PNG 시퀀스"
                              IsEnabled="{Binding HasFrames}"
                              Click="ExportPngSequenceMenuItem_Click" />
                </MenuItem>
                <Separator />
                <MenuItem Header="옵션..."
                          Click="OptionsMenuItem_Click" />
                <MenuItem Header="종료"
                          InputGestureText="Alt+F4"
                          Click="ExitMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="편집">
                <MenuItem Header="캔버스 크롭"
                          InputGestureText="Ctrl+Shift+X"
                          IsEnabled="{Binding CanCropCanvas}"
                          Click="CropMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="Tools">
                <MenuItem Header="Make AniGIF"
                          Click="MakeAniGifMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1"
                Margin="10,10,10,6"
                Background="{StaticResource Brush.ViewportBackground}"
                BorderBrush="{StaticResource Brush.BorderDefault}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14">
                    <Border Background="{StaticResource Brush.SurfaceBackground}"
                            BorderBrush="{StaticResource Brush.BorderSubtle}"
                            BorderThickness="1"
                            Padding="20"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Canvas x:Name="PreviewOverlayCanvas"
                                Width="1"
                                Height="1"
                                Background="Transparent"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                MouseLeftButtonDown="PreviewOverlayCanvas_MouseLeftButtonDown"
                                MouseMove="PreviewOverlayCanvas_MouseMove"
                                MouseLeftButtonUp="PreviewOverlayCanvas_MouseLeftButtonUp">
                            <Canvas.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomFactor}"
                                                ScaleY="{Binding ZoomFactor}" />
                            </Canvas.LayoutTransform>

                            <Canvas x:Name="PreviewCanvasHost"
                                    Width="1"
                                    Height="1"
                                    Visibility="Collapsed"
                                    Background="{StaticResource Brush.SurfaceBackground}"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                <Image x:Name="PreviewFrameImage"
                                       Visibility="Collapsed"
                                       Stretch="None"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True" />
                            </Canvas>

                            <Rectangle x:Name="PreviewCanvasBounds"
                                       Visibility="Collapsed"
                                       Fill="Transparent"
                                       Stroke="{StaticResource Brush.BorderStrong}"
                                       StrokeThickness="1"
                                       SnapsToDevicePixels="True" />

                            <Rectangle x:Name="PreviewSelectionRectangle"
                                       Visibility="Collapsed"
                                       Stroke="{StaticResource Brush.Warning}"
                                       StrokeThickness="2"
                                       Fill="{StaticResource Brush.WarningOverlay}" />
                        </Canvas>
                    </Border>
                </ScrollViewer>

                <TextBlock Text="{Binding EmptyFrameMessage}"
                           Foreground="{StaticResource Brush.TextPlaceholder}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFrames}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="2"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="{StaticResource Brush.BorderDefault}" />

        <Border Grid.Row="3"
                Margin="10,6,10,10"
                Background="{StaticResource Brush.SurfaceBackground}"
                BorderBrush="{StaticResource Brush.BorderDefault}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="8,6,8,6">
                    <Border DockPanel.Dock="Left"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="{StaticResource Brush.SurfaceAccent}">
                        <UniformGrid Rows="1" Columns="3">
                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0,0,1,0"
                                    Click="PreviousFrameButton_Click"
                                    ToolTip="Previous frame">
                                <Path Fill="{StaticResource Brush.Icon}" Data="M1,1 H3 V15 H1 Z M14,1 L4,8 L14,15 Z" />
                            </Button>

                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0,0,1,0"
                                    Click="PlayPauseButton_Click"
                                    ToolTip="Play/Pause">
                                <Grid Width="14" Height="14">
                                    <Path Fill="{StaticResource Brush.Icon}" Data="M2,1 L13,8 L2,15 Z">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Rectangle Fill="{StaticResource Brush.Icon}"
                                               Width="10"
                                               Height="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource TransportButtonStyle}"
                                    BorderThickness="0"
                                    Click="NextFrameButton_Click"
                                    ToolTip="Next frame">
                                <Path Fill="{StaticResource Brush.Icon}" Data="M13,1 H15 V15 H13 Z M2,1 L12,8 L2,15 Z" />
                            </Button>
                        </UniformGrid>
                    </Border>

                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource TransportButtonStyle}"
                            Width="40"
                            Margin="8,0,0,0"
                            Click="AddFramesButton_Click"
                            ToolTip="Add frame images">
                        <Path Stroke="{StaticResource Brush.Icon}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M8,2 V14 M2,8 H14" />
                    </Button>

                    <CheckBox Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource Brush.TextSecondary}"
                              Content="루프"
                              IsChecked="{Binding IsLoopEnabled}"
                              ToolTip="켜면 좌우 이동과 재생이 순환합니다." />

                    <TextBlock VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Text="{Binding CurrentFrameSummary}" />
                </DockPanel>

                <ListBox Grid.Row="1"
                         x:Name="ThumbnailList"
                         Margin="6,0,6,6"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         ItemsSource="{Binding Frames}"
                         SelectedIndex="{Binding SelectedFrameIndex, Mode=TwoWay}"
                         SelectionChanged="ThumbnailList_SelectionChanged"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="ThumbnailList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ThumbnailList_PreviewMouseMove"
                         PreviewDragOver="ThumbnailList_PreviewDragOver"
                         Drop="ThumbnailList_Drop"
                         SizeChanged="ThumbnailList_SizeChanged"
                         ItemContainerStyle="{StaticResource ThumbnailItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6"
                                    Padding="6"
                                    MinWidth="92"
                                    Background="{StaticResource Brush.SurfaceCard}"
                                    BorderBrush="{StaticResource Brush.BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel>
                                    <Image Source="{Binding Image}"
                                           Height="{Binding DataContext.ThumbnailHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                           Stretch="Uniform" />
                                    <TextBlock Text="{Binding Name}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource Brush.TextSecondary}"
                                               FontSize="11"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
