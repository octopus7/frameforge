<Window x:Class="FrameForge.VideoRuntimeInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FFmpeg 설치"
        Width="460"
        Height="170"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.WindowBackground}">
    <Border Margin="12"
            Padding="18"
            Background="{StaticResource Brush.SurfaceBackground}"
            BorderBrush="{StaticResource Brush.BorderDefault}"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel>
            <TextBlock Text="FFmpeg 런타임 설치 중"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />
            <TextBlock Margin="0,10,0,0"
                       Text="{Binding StatusText}"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       TextWrapping="Wrap" />
            <ProgressBar Margin="0,16,0,0"
                         Height="12"
                         IsIndeterminate="{Binding IsIndeterminate, Mode=OneWay}"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}" />
        </StackPanel>
    </Border>
</Window>
