<Window x:Class="FrameForge.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="옵션"
        Width="760"
        Height="500"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.WindowBackground}">
    <Grid Margin="12">
        <TabControl TabStripPlacement="Left"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.BorderDefault}"
                    Foreground="{StaticResource Brush.TextPrimary}">
            <TabItem Header="확장자 연결">
                <Border Margin="14"
                        Padding="18"
                        Background="{StaticResource Brush.SurfaceBackground}"
                        BorderBrush="{StaticResource Brush.BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="프로젝트 파일 확장자 연결" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text=".ffproj 파일을 FrameForge와 연결하면 탐색기에서 더블클릭으로 프로젝트를 바로 열 수 있습니다." />

                        <Border Grid.Row="2"
                                Margin="0,16,0,0"
                                Padding="10"
                                Background="{StaticResource Brush.SurfaceRaised}"
                                BorderBrush="{StaticResource Brush.BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap"
                                       Text="현재 사용자(HKCU) 범위로 등록됩니다. 관리자 권한은 필요하지 않습니다." />
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <Button Width="130"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="AssociateExtensionButton_Click"
                                    Content="확장자 연결" />
                            <Button Width="90"
                                    Height="34"
                                    IsCancel="True"
                                    Content="닫기" />
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
