<Window x:Class="FrameForge.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="옵션"
        Width="860"
        Height="560"
        MinWidth="720"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.WindowBackground}">
    <Grid Margin="12">
        <TabControl x:Name="OptionsTabControl"
                    TabStripPlacement="Left"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.BorderDefault}"
                    Foreground="{StaticResource Brush.TextPrimary}">
            <TabItem x:Name="ExtensionAssociationTab" Header="확장자 연결">
                <Border Margin="14"
                        Padding="18"
                        Background="{StaticResource Brush.SurfaceBackground}"
                        BorderBrush="{StaticResource Brush.BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="프로젝트 파일 확장자 연결" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text=".ffproj 파일을 FrameForge와 연결하면 탐색기에서 더블클릭으로 프로젝트를 바로 열 수 있습니다." />

                        <Border Grid.Row="2"
                                Margin="0,16,0,0"
                                Padding="10"
                                Background="{StaticResource Brush.SurfaceRaised}"
                                BorderBrush="{StaticResource Brush.BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <TextBlock Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap"
                                       Text="현재 사용자(HKCU) 범위로 등록됩니다. 관리자 권한은 필요하지 않습니다." />
                        </Border>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <Button Width="130"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="AssociateExtensionButton_Click"
                                    Content="확장자 연결" />
                            <Button Width="90"
                                    Height="34"
                                    IsCancel="True"
                                    Content="닫기" />
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem x:Name="VideoRuntimeTab" Header="FFmpeg">
                <Border Margin="14"
                        Padding="18"
                        Background="{StaticResource Brush.SurfaceBackground}"
                        BorderBrush="{StaticResource Brush.BorderDefault}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   Text="동영상 임포트용 FFmpeg 런타임" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Text="{Binding RuntimeSourceText}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource Brush.TextMuted}"
                                   TextWrapping="Wrap"
                                   Text="{Binding DefaultRuntimeDirectoryText}" />

                        <StackPanel Grid.Row="3" Margin="0,16,0,0">
                            <TextBlock Text="런타임 경로"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="RuntimePathTextBox"
                                         MinHeight="34"
                                         Padding="8,6"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding RuntimePathInput, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        MinWidth="92"
                                        Click="BrowseRuntimePathButton_Click"
                                        Content="찾아보기" />
                            </Grid>
                        </StackPanel>

                        <Border Grid.Row="4"
                                Margin="0,16,0,0"
                                Padding="12"
                                Background="{StaticResource Brush.SurfaceRaised}"
                                BorderBrush="{StaticResource Brush.BorderStrong}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="{Binding RuntimeStatusText}"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding RuntimeDetailText}"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="5"
                                    Margin="0,16,0,0">
                            <TextBlock Text="작업"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}" />
                            <WrapPanel Margin="0,10,0,0"
                                       ItemHeight="34"
                                       ItemWidth="140">
                                <Button Margin="0,0,8,8"
                                        Click="ApplyRuntimePathButton_Click"
                                        IsEnabled="{Binding CanEditRuntimeSettings}"
                                        Content="경로 적용" />
                                <Button Margin="0,0,8,8"
                                        Click="UseDefaultRuntimePathButton_Click"
                                        IsEnabled="{Binding CanEditRuntimeSettings}"
                                        Content="기본 경로 사용" />
                                <Button Margin="0,0,8,8"
                                        Click="InstallDefaultRuntimeButton_Click"
                                        IsEnabled="{Binding CanEditRuntimeSettings}"
                                        Content="기본 위치에 설치" />
                                <Button Margin="0,0,8,8"
                                        Click="OpenRuntimeFolderButton_Click"
                                        Content="폴더 열기" />
                            </WrapPanel>

                            <Border Margin="0,8,0,0"
                                    Padding="12"
                                    Background="{StaticResource Brush.SurfaceRaised}"
                                    BorderBrush="{StaticResource Brush.BorderDefault}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Text="{Binding RuntimeInstallProgressText}"
                                               Foreground="{StaticResource Brush.TextSecondary}" />
                                    <ProgressBar Margin="0,10,0,0"
                                                 Height="10"
                                                 IsIndeterminate="{Binding IsRuntimeInstallIndeterminate, Mode=OneWay}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding RuntimeInstallPercent, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,16,0,0">
                            <Button Width="90"
                                    Height="34"
                                    IsCancel="True"
                                    Content="닫기" />
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
