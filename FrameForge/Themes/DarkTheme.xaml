<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FrameForge">
    <Color x:Key="Color.WindowBackground">#1A1A1A</Color>
    <Color x:Key="Color.ViewportBackground">#101010</Color>
    <Color x:Key="Color.SurfaceBackground">#141414</Color>
    <Color x:Key="Color.SurfaceRaised">#1E1E1E</Color>
    <Color x:Key="Color.SurfaceCard">#222222</Color>
    <Color x:Key="Color.SurfaceAccent">#262626</Color>
    <Color x:Key="Color.ControlBackground">#2C2C2C</Color>
    <Color x:Key="Color.ControlHover">#3A3A3A</Color>
    <Color x:Key="Color.ControlPressed">#1E1E1E</Color>
    <Color x:Key="Color.BorderSubtle">#2A2A2A</Color>
    <Color x:Key="Color.BorderDefault">#2F2F2F</Color>
    <Color x:Key="Color.BorderStrong">#4A4A4A</Color>
    <Color x:Key="Color.TextPrimary">#F2F2F2</Color>
    <Color x:Key="Color.TextSecondary">#D0D0D0</Color>
    <Color x:Key="Color.TextMuted">#A8A8A8</Color>
    <Color x:Key="Color.TextPlaceholder">#7D7D7D</Color>
    <Color x:Key="Color.Icon">#EFEFEF</Color>
    <Color x:Key="Color.AccentBackground">#233549</Color>
    <Color x:Key="Color.AccentBorder">#66B6FF</Color>
    <Color x:Key="Color.AccentFocus">#9DD0FF</Color>
    <Color x:Key="Color.MenuHighlight">#35506A</Color>
    <Color x:Key="Color.Warning">#FFE36A</Color>
    <Color x:Key="Color.WarningOverlay">#33FFE36A</Color>
    <Color x:Key="Color.HintBackground">#F2FFF2C2</Color>
    <Color x:Key="Color.HintBorder">#CC7F6A00</Color>
    <Color x:Key="Color.HintText">#2A2200</Color>
    <Color x:Key="Color.ScrollTrack">#171717</Color>
    <Color x:Key="Color.ScrollThumb">#3A3A3A</Color>
    <Color x:Key="Color.ScrollThumbHover">#4A4A4A</Color>
    <Color x:Key="Color.ScrollThumbActive">#5A5A5A</Color>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="{StaticResource Color.WindowBackground}" />
    <SolidColorBrush x:Key="Brush.ViewportBackground" Color="{StaticResource Color.ViewportBackground}" />
    <SolidColorBrush x:Key="Brush.SurfaceBackground" Color="{StaticResource Color.SurfaceBackground}" />
    <SolidColorBrush x:Key="Brush.SurfaceRaised" Color="{StaticResource Color.SurfaceRaised}" />
    <SolidColorBrush x:Key="Brush.SurfaceCard" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="Brush.SurfaceAccent" Color="{StaticResource Color.SurfaceAccent}" />
    <SolidColorBrush x:Key="Brush.ControlBackground" Color="{StaticResource Color.ControlBackground}" />
    <SolidColorBrush x:Key="Brush.ControlHover" Color="{StaticResource Color.ControlHover}" />
    <SolidColorBrush x:Key="Brush.ControlPressed" Color="{StaticResource Color.ControlPressed}" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="{StaticResource Color.BorderSubtle}" />
    <SolidColorBrush x:Key="Brush.BorderDefault" Color="{StaticResource Color.BorderDefault}" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="{StaticResource Color.TextPlaceholder}" />
    <SolidColorBrush x:Key="Brush.Icon" Color="{StaticResource Color.Icon}" />
    <SolidColorBrush x:Key="Brush.AccentBackground" Color="{StaticResource Color.AccentBackground}" />
    <SolidColorBrush x:Key="Brush.AccentBorder" Color="{StaticResource Color.AccentBorder}" />
    <SolidColorBrush x:Key="Brush.AccentFocus" Color="{StaticResource Color.AccentFocus}" />
    <SolidColorBrush x:Key="Brush.MenuHighlight" Color="{StaticResource Color.MenuHighlight}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.WarningOverlay" Color="{StaticResource Color.WarningOverlay}" />
    <SolidColorBrush x:Key="Brush.HintBackground" Color="{StaticResource Color.HintBackground}" />
    <SolidColorBrush x:Key="Brush.HintBorder" Color="{StaticResource Color.HintBorder}" />
    <SolidColorBrush x:Key="Brush.HintText" Color="{StaticResource Color.HintText}" />
    <SolidColorBrush x:Key="Brush.ScrollTrack" Color="{StaticResource Color.ScrollTrack}" />
    <SolidColorBrush x:Key="Brush.ScrollThumb" Color="{StaticResource Color.ScrollThumb}" />
    <SolidColorBrush x:Key="Brush.ScrollThumbHover" Color="{StaticResource Color.ScrollThumbHover}" />
    <SolidColorBrush x:Key="Brush.ScrollThumbActive" Color="{StaticResource Color.ScrollThumbActive}" />

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource Color.WindowBackground}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource Color.ControlBackground}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{StaticResource Color.SurfaceRaised}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="{StaticResource Color.ViewportBackground}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{StaticResource Color.ControlHover}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="{StaticResource Color.BorderStrong}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource Color.MenuHighlight}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{StaticResource Color.SurfaceRaised}" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource Color.TextSecondary}" />

    <SolidColorBrush x:Key="Menu.Static.Background" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="Menu.Static.Border" Color="{StaticResource Color.BorderDefault}" />
    <SolidColorBrush x:Key="Menu.Static.Foreground" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="MenuItem.Static.Background" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="MenuItem.Static.Border" Color="{StaticResource Color.SurfaceCard}" />
    <SolidColorBrush x:Key="MenuItem.Static.Foreground" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="MenuItem.Highlight.Background" Color="{StaticResource Color.AccentBackground}" />
    <SolidColorBrush x:Key="MenuItem.Highlight.Border" Color="{StaticResource Color.AccentBorder}" />
    <SolidColorBrush x:Key="MenuItem.Selected.Background" Color="{StaticResource Color.AccentBackground}" />
    <SolidColorBrush x:Key="MenuItem.Selected.Border" Color="{StaticResource Color.AccentBorder}" />
    <SolidColorBrush x:Key="MenuItem.Disabled.Foreground" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="MenuItem.Disabled.Glyph" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="MenuItem.Separator.Background" Color="{StaticResource Color.BorderDefault}" />
    <SolidColorBrush x:Key="MenuItem.Separator.Border" Color="{StaticResource Color.BorderDefault}" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource Brush.WindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="TextElement.Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="local:WindowThemeManager.EnableDarkCaption" Value="True" />
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceCard}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1"
                            Margin="4,3"
                            Background="{StaticResource Brush.BorderDefault}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Brush.ControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Brush.ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource Brush.ControlPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceRaised}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceRaised}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabRoot"
                            Margin="2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <ContentPresenter ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                            <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource Brush.ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="TabRoot" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceCard}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderDefault}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,4" />
    </Style>

    <Style x:Key="DarkScrollBarLineButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="{StaticResource Brush.ScrollTrack}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{StaticResource Brush.ScrollThumb}" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbRoot"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.ScrollThumbHover}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource Brush.ScrollThumbActive}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource Brush.ScrollTrack}" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton x:Name="PART_DecreaseButton"
                                              Style="{StaticResource DarkScrollBarLineButtonStyle}"
                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource DarkScrollBarThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton x:Name="PART_IncreaseButton"
                                              Style="{StaticResource DarkScrollBarLineButtonStyle}"
                                              CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=ScrollBar}}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Height" Value="12" />
                            <Setter Property="Width" Value="Auto" />
                            <Setter TargetName="PART_DecreaseButton" Property="Command" Value="{x:Static ScrollBar.LineLeftCommand}" />
                            <Setter TargetName="PART_IncreaseButton" Property="Command" Value="{x:Static ScrollBar.LineRightCommand}" />
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="PART_DecreaseButton" Property="Command" Value="{x:Static ScrollBar.LineUpCommand}" />
                            <Setter TargetName="PART_IncreaseButton" Property="Command" Value="{x:Static ScrollBar.LineDownCommand}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
