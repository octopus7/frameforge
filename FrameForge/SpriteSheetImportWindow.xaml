<Window x:Class="FrameForge.SpriteSheetImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="단일 이미지에서 시트 가져오기"
        Width="980"
        Height="720"
        MinWidth="680"
        MinHeight="460"
        Background="#1B1B1B"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Border Margin="10"
                Background="#101010"
                BorderBrush="#2E2E2E"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <ScrollViewer x:Name="ImageScrollViewer"
                              Visibility="Collapsed"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16"
                              Background="#111111">
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Image x:Name="SourceImageView"
                               Stretch="None"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True" />

                        <Canvas x:Name="OverlayCanvas"
                                Width="{Binding ElementName=SourceImageView, Path=ActualWidth}"
                                Height="{Binding ElementName=SourceImageView, Path=ActualHeight}"
                                Background="Transparent"
                                MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                                MouseMove="OverlayCanvas_MouseMove"
                                MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">
                            <Rectangle x:Name="SelectionRectangle"
                                       Visibility="Collapsed"
                                       Stroke="#FFE36A"
                                       StrokeThickness="2"
                                       Fill="#33FFE36A" />

                            <Border x:Name="SelectionHint"
                                    Visibility="Collapsed"
                                    Padding="6,3"
                                    CornerRadius="4"
                                    BorderBrush="#CC7F6A00"
                                    BorderThickness="1"
                                    Background="#F2FFF2C2">
                                <TextBlock Text="스페이스 키를 누르면 프레임으로 추가"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#2A2200" />
                            </Border>
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <Grid x:Name="LoadPanel">
                    <Button Width="190"
                            Height="58"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="LoadImageButton_Click"
                            Cursor="Hand"
                            Background="#2C2C2C"
                            Foreground="#F3F3F3"
                            BorderBrush="#4A4A4A">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16"
                                  Height="16"
                                  Margin="0,0,8,0"
                                  Stroke="#F3F3F3"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M8,2 V14 M2,8 H14" />
                            <TextBlock Text="불러오기"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
