<Window x:Class="FrameForge.PngSequenceExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PNG 시퀀스 익스포트"
        Width="560"
        MinWidth="520"
        MinHeight="340"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.WindowBackground}">
    <Border Margin="12"
            Padding="18"
            Background="{StaticResource Brush.SurfaceBackground}"
            BorderBrush="{StaticResource Brush.BorderDefault}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="PNG 시퀀스로 내보내기"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="출력 폴더"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ExportDirectoryTextBox"
                             MinHeight="34"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            MinWidth="92"
                            Click="BrowseDirectoryButton_Click"
                            Content="찾아보기" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                <TextBlock Text="파일 프리픽스"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />
                <TextBox x:Name="FilePrefixTextBox"
                         Margin="0,8,0,0"
                         MinHeight="34"
                         Padding="8,6"
                         VerticalContentAlignment="Center"
                         Text="{Binding FilePrefix, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="{Binding PreviewFileNameText}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource Brush.Warning}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button MinWidth="92"
                        IsCancel="True"
                        Content="취소" />
                <Button MinWidth="110"
                        Margin="8,0,0,0"
                        IsEnabled="{Binding CanExport}"
                        Click="ExportButton_Click"
                        Content="내보내기" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
