<Window x:Class="FrameForge.VideoImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="동영상에서 프레임 가져오기"
        Width="1320"
        Height="820"
        MinWidth="960"
        MinHeight="620"
        Background="{StaticResource Brush.WindowBackground}"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="FrameListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{StaticResource Brush.SurfaceCard}"
                                BorderBrush="{StaticResource Brush.BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Brush.AccentBackground}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentFocus}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource Brush.SurfaceBackground}"
                    BorderBrush="{StaticResource Brush.BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="12,12,12,10">
                        <Button Height="38"
                                Click="LoadVideoButton_Click"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Path Width="16"
                                      Height="16"
                                      Margin="0,0,8,0"
                                      Stroke="{StaticResource Brush.Icon}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M8,2 V14 M2,8 H14" />
                                <TextBlock Text="동영상 불러오기"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding Session.SourceVideoName}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding LoadProgressText}"
                                   Foreground="{StaticResource Brush.TextMuted}" />

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding Session.LoadError}"
                                   Foreground="{StaticResource Brush.Warning}"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Session.HasLoadError}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="12,0,12,12">
                        <Border Background="{StaticResource Brush.ViewportBackground}"
                                BorderBrush="{StaticResource Brush.BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ListBox x:Name="FrameList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10"
                                     SelectionMode="Extended"
                                     ItemsSource="{Binding Session.Frames}"
                                     ItemContainerStyle="{StaticResource FrameListItemStyle}"
                                     PreviewMouseLeftButtonDown="FrameList_PreviewMouseLeftButtonDown"
                                     SelectionChanged="FrameList_SelectionChanged"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource Brush.AccentBorder}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Grid.Row="1"
                                                       Margin="0,4,0,0"
                                                       Text="{Binding Subtitle}"
                                                       Foreground="{StaticResource Brush.TextMuted}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <TextBlock Text="동영상을 불러오면 프레임 목록이 여기에 표시됩니다."
                                   Margin="24"
                                   Foreground="{StaticResource Brush.TextPlaceholder}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Session.HasFrames}" Value="False" />
                                                <Condition Binding="{Binding Session.IsLoading}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="12,0,12,12"
                            Background="{StaticResource Brush.SurfaceAccent}"
                            BorderBrush="{StaticResource Brush.BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <UniformGrid Rows="1" Columns="4">
                            <Button BorderThickness="0,0,1,0"
                                    IsEnabled="{Binding CanDeleteFrames}"
                                    Click="DeleteFramesButton_Click"
                                    Content="삭제" />
                            <Button BorderThickness="0,0,1,0"
                                    IsEnabled="{Binding CanCropFrames}"
                                    Click="CropFramesButton_Click"
                                    Content="크롭" />
                            <Button BorderThickness="0,0,1,0"
                                    IsEnabled="{Binding CanInvertSelection}"
                                    Click="InvertSelectionButton_Click"
                                    Content="선택 반전" />
                            <Button BorderThickness="0"
                                    IsEnabled="False"
                                    Content="" />
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource Brush.ViewportBackground}"
                    BorderBrush="{StaticResource Brush.BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="14,12,14,10">
                        <TextBlock Text="액티브 프레임"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding ActiveFrameSummary}"
                                   Foreground="{StaticResource Brush.TextMuted}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="16">
                            <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                                <Image x:Name="ActiveFrameImageView"
                                       Source="{Binding Session.ActiveFrameImage}"
                                       Stretch="None"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True" />

                                <Canvas x:Name="PreviewOverlayCanvas"
                                        Width="{Binding ElementName=ActiveFrameImageView, Path=ActualWidth}"
                                        Height="{Binding ElementName=ActiveFrameImageView, Path=ActualHeight}"
                                        Background="Transparent"
                                        MouseLeftButtonDown="PreviewOverlayCanvas_MouseLeftButtonDown"
                                        MouseMove="PreviewOverlayCanvas_MouseMove"
                                        MouseLeftButtonUp="PreviewOverlayCanvas_MouseLeftButtonUp"
                                        LostMouseCapture="PreviewOverlayCanvas_LostMouseCapture">
                                    <Rectangle x:Name="CropSelectionShadow"
                                               Visibility="Collapsed"
                                               Stroke="{StaticResource Brush.CropSelectionShadow}"
                                               StrokeThickness="1"
                                               StrokeDashArray="6 4"
                                               Fill="{StaticResource Brush.CropSelectionFill}">
                                        <Rectangle.Triggers>
                                            <EventTrigger RoutedEvent="Rectangle.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                                                         From="0"
                                                                         To="-20"
                                                                         Duration="0:0:0.6" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>

                                    <Rectangle x:Name="CropSelectionHighlight"
                                               Visibility="Collapsed"
                                               Stroke="{StaticResource Brush.TextPrimary}"
                                               StrokeThickness="1"
                                               StrokeDashArray="6 4"
                                               StrokeDashOffset="10"
                                               Fill="Transparent">
                                        <Rectangle.Triggers>
                                            <EventTrigger RoutedEvent="Rectangle.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset"
                                                                         From="20"
                                                                         To="0"
                                                                         Duration="0:0:0.6" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Rectangle.Triggers>
                                    </Rectangle>
                                </Canvas>
                            </Grid>
                        </ScrollViewer>

                        <TextBlock Text="동영상을 불러오면 액티브 프레임이 여기에 표시됩니다."
                                   Margin="32"
                                   Foreground="{StaticResource Brush.TextPlaceholder}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Session.HasFrames}" Value="False" />
                                                <Condition Binding="{Binding Session.IsLoading}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border Background="{StaticResource Brush.LoadOverlay}"
                                CornerRadius="6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Session.IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ProgressBar Width="260"
                                             Height="10"
                                             IsIndeterminate="True" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding LoadProgressText}"
                                           Foreground="{StaticResource Brush.TextPrimary}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button MinWidth="100"
                    Click="CancelButton_Click"
                    Content="취소" />
            <Button MinWidth="100"
                    Margin="8,0,0,0"
                    IsEnabled="{Binding CanConfirmImport}"
                    Click="ConfirmButton_Click"
                    Content="가져오기" />
        </StackPanel>
    </Grid>
</Window>
