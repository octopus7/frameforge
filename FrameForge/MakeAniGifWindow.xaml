<Window x:Class="FrameForge.MakeAniGifWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Make AniGIF"
        Width="640"
        MinWidth="600"
        MinHeight="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Brush.WindowBackground}">
    <Border Margin="12"
            Padding="18"
            Background="{StaticResource Brush.SurfaceBackground}"
            BorderBrush="{StaticResource Brush.BorderDefault}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="PNG 시퀀스로 AniGIF 만들기"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}" />

            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <TextBlock Text="샘플 PNG 파일 경로"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SamplePngPathTextBox"
                             MinHeight="34"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding SamplePngPath, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Column="1"
                            Margin="8,0,0,0"
                            MinWidth="92"
                            Click="BrowseSamplePngButton_Click"
                            Content="찾아보기" />
                </Grid>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="프리픽스"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBox Margin="0,8,0,0"
                             MinHeight="34"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding FramePrefix, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="시작 번호"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBox Margin="0,8,0,0"
                             MinHeight="34"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding StartNumberText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="끝 번호"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}" />
                    <TextBox Margin="0,8,0,0"
                             MinHeight="34"
                             Padding="8,6"
                             VerticalContentAlignment="Center"
                             Text="{Binding EndNumberText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="3"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="{Binding SequenceStatusText}"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Text="기본 프레임 간격: 125ms (1/8초, GIF 저장 시 10ms 단위 반올림)"
                               Foreground="{StaticResource Brush.TextMuted}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4"
                    Margin="0,16,0,0"
                    Padding="12"
                    Background="{StaticResource Brush.SurfaceRaised}"
                    BorderBrush="{StaticResource Brush.BorderDefault}"
                    BorderThickness="1"
                    CornerRadius="6">
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="{StaticResource Brush.Warning}"
                           TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button MinWidth="92"
                        IsCancel="True"
                        Content="닫기" />
                <Button MinWidth="110"
                        Margin="8,0,0,0"
                        IsEnabled="{Binding CanGenerateGif}"
                        Click="GenerateGifButton_Click"
                        Content="GIF 생성" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
